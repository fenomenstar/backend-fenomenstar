# ===================================
# FenomenStar Backend - Environment Variables
# ===================================
# Copy this file to .env and configure values
# DO NOT commit .env to version control
# ===================================

# ===== SERVER =====
PORT=3000
NODE_ENV=development
# Options: development, production, test

# ===== DATABASE =====
# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/fenomenstar
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=20

# ===== REDIS =====
REDIS_URL=redis://localhost:6379

# ===== JWT SECRETS =====
# MUST be at least 64 characters for security
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ===== S3 / CLOUDFLARE R2 STORAGE =====
# For Cloudflare R2:
#   S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
#   S3_REGION=auto
# For AWS S3:
#   S3_ENDPOINT= (leave empty)
#   S3_REGION=us-east-1
S3_ENDPOINT=
S3_REGION=auto
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=fenomenstar-media
S3_PUBLIC_URL=
# CDN URL for public access (e.g., https://cdn.fenomenstar.com)

# ===== WEBRTC / TURN SERVER =====
# Required for live streaming to work behind NAT/firewalls
# Deploy coturn or use a service like Twilio
TURN_SECRET=
TURN_SERVER=
TURN_PROVIDER=static
CLOUDFLARE_TURN_KEY_ID=
CLOUDFLARE_TURN_API_TOKEN=
# Example: turn:turn.fenomenstar.com:3478

# ===== MONITORING =====
# Sentry error tracking
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_RELEASE=

# Logging
LOG_LEVEL=debug
# Options: error, warn, info, http, debug

# ===== CORS =====
# Comma-separated origins or * for all
CORS_ORIGIN=*
# Production example: https://fenomenstar.com,https://www.fenomenstar.com

# ===== APP =====
APP_NAME=FenomenStar
APP_VERSION=1.0.0

# ===== SUPABASE AUTH (OPTIONAL) =====
# If true, backend will validate access tokens via Supabase Auth.
USE_SUPABASE_AUTH=false
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
MODERATION_PROVIDER=local
HUGGINGFACE_API_KEY=
HUGGINGFACE_MODERATION_MODEL=facebook/roberta-hate-speech-dynabench-r4-target
HUGGINGFACE_EMBEDDING_MODEL=intfloat/multilingual-e5-large

# ===== PLAY REVIEW =====
PLAY_REVIEW_TEST_EMAIL=fenomenstar_user_review@fenomenstar.com
PLAY_REVIEW_TEST_PASSWORD=
PLAY_REVIEW_TEST_NAME=FenomenStar Review User
PLAY_REVIEW_TEST_ROLE=viewer
